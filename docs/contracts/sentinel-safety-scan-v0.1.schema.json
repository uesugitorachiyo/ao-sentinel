{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/contracts/sentinel-safety-scan-v0.1.schema.json",
  "title": "AO Sentinel Safety Scan v0.1",
  "type": "object",
  "required": ["schema_version", "status", "path", "findings_count", "findings", "scanned_at_utc"],
  "properties": {
    "schema_version": { "const": "ao.sentinel.safety-scan.v0.1" },
    "status": { "enum": ["passed", "failed"] },
    "findings_count": { "type": "integer" },
    "findings": { "type": "array" }
  },
  "additionalProperties": true
}
