{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-sentinel/docs/contracts/sentinel-security-review-request-v0.1.schema.json",
  "title": "AO Sentinel Security Review Request v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "review_id",
    "target_id",
    "repository",
    "change_summary",
    "scopes",
    "evidence",
    "observed_at_utc"
  ],
  "properties": {
    "schema_version": {
      "const": "ao.sentinel.security-review-request.v0.1"
    },
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "change_summary": {
      "type": "string",
      "minLength": 1
    },
    "scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "secrets",
          "input_validation",
          "authorization",
          "dependencies",
          "logging",
          "public_artifacts"
        ]
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "observed_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
