{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/contracts/sentinel-target-v0.1.schema.json",
  "title": "AO Sentinel Target v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "target_id",
    "target_kind",
    "active_stack_ref",
    "watch_scope",
    "watched_components",
    "platform_matrix",
    "risk_budget",
    "dry_run_only"
  ],
  "properties": {
    "schema_version": { "const": "ao.sentinel.target.v0.1" },
    "target_id": { "type": "string", "minLength": 1 },
    "target_kind": { "enum": ["active_stack", "candidate_stack", "component", "release_candidate"] },
    "active_stack_ref": { "type": "string", "minLength": 1 },
    "watch_scope": { "type": "array", "items": { "type": "string" } },
    "watched_components": { "type": "array", "items": { "type": "string" } },
    "platform_matrix": { "type": "array", "items": { "type": "string" } },
    "risk_budget": { "type": "object" },
    "dry_run_only": { "const": true }
  },
  "additionalProperties": true
}
