{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/contracts/sentinel-live-mutation-hold-v0.1.schema.json",
  "title": "AO Sentinel Live Mutation Hold v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "mutation_class",
    "class_hold_verdict",
    "hold_required",
    "promoter_hold_required",
    "rollback_recommended",
    "blockers",
    "recommended_actions",
    "source_artifacts",
    "operator_mode",
    "mutates_live_state",
    "mutates_repositories",
    "schedules_work",
    "executes_work",
    "approves_work",
    "provider_calls_allowed",
    "release_or_publish_allowed"
  ],
  "properties": {
    "schema_version": { "const": "ao.sentinel.live-mutation-hold.v0.1" },
    "status": { "enum": ["clear", "hold"] },
    "mutation_class": {
      "enum": [
        "docs_only_single_file",
        "docs_only_multi_file",
        "docs_config_only",
        "test_only",
        "low_risk_code",
        "multi_repo_low_risk",
        "complex_repo_mutation"
      ]
    },
    "class_hold_verdict": {
      "type": "object",
      "required": [
        "status",
        "mutation_class",
        "test_coverage_status",
        "rollback_status",
        "diff_size_status",
        "file_class_status",
        "evidence_freshness_status",
        "ci_status",
        "blockers"
      ],
      "properties": {
        "status": { "enum": ["clear", "hold"] },
        "mutation_class": { "type": "string" },
        "max_files": { "type": "number" },
        "max_lines_changed": { "type": "number" },
        "files_changed": { "type": "number" },
        "lines_changed": { "type": "number" },
        "test_coverage_status": { "type": "string" },
        "rollback_status": { "type": "string" },
        "diff_size_status": { "type": "string" },
        "file_class_status": { "type": "string" },
        "evidence_freshness_status": { "type": "string" },
        "ci_status": { "type": "string" },
        "blockers": { "type": "array" }
      },
      "additionalProperties": true
    },
    "hold_required": { "type": "boolean" },
    "promoter_hold_required": { "type": "boolean" },
    "rollback_recommended": { "type": "boolean" },
    "blockers": { "type": "array" },
    "recommended_actions": { "type": "array" },
    "source_artifacts": { "type": "array" },
    "operator_mode": { "const": "read_only" },
    "mutates_live_state": { "const": false },
    "mutates_repositories": { "const": false },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "provider_calls_allowed": { "const": false },
    "release_or_publish_allowed": { "const": false }
  },
  "additionalProperties": true
}
