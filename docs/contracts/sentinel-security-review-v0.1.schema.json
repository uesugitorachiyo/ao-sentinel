{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uesugitorachiyo/ao-sentinel/docs/contracts/sentinel-security-review-v0.1.schema.json",
  "title": "AO Sentinel Security Review v0.1",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "review_id",
    "target_id",
    "repository",
    "severity",
    "scopes_checked",
    "evidence",
    "findings",
    "recommended_actions",
    "promoter_hold_required",
    "mutates_live_state",
    "generated_at_utc",
    "observed_request_at_utc"
  ],
  "properties": {
    "schema_version": {
      "const": "ao.sentinel.security-review.v0.1"
    },
    "status": {
      "type": "string",
      "enum": ["clear", "hold"]
    },
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["info", "medium", "high", "critical"]
    },
    "scopes_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scope", "severity", "summary", "recommended_action"],
        "properties": {
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["medium", "high", "critical"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "recommended_action": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "promoter_hold_required": {
      "type": "boolean"
    },
    "mutates_live_state": {
      "const": false
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "observed_request_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
